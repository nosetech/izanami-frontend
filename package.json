    "@mui/icons-material": "^7.1.2",
    "@mui/lab": "^7.0.0-beta.16",
    "@mui/material": "^7.1.2",
    "@mui/material-nextjs": "^7.1.1",
    "axios": "^1.10.0",
    "axios-hooks": "^5.1.1",
    "graphql": "^16.11.0",
    "js-cookie": "^3.0.5",
    "lru-cache": "^11.1.0",
    "next": "15.3.4",
    "react": "^19.0.0",
